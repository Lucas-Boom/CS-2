def factorial(n): 
    '''
    Description: gives you the factorial of any non-negative number inputed
    Args: 
        n (int): A non-negative number
    Returns: the factorial of n
    '''

    if n == 0: #if n equals 1
        return 1 #return 1
    else: 
        return n * factorial(n - 1) # else return the factorial root of that -1 of each number every time

def summation(n):
    '''
    Description: the sum of all the numbers from n down to 0
    Args: 
        n (int): A non-negative number
    Returns: the total sum of numbers from n to 0
    '''

    if n > 0:
        return n + summation(n-1)
    elif n == 0:
        return 0
    
def powers(a, n): 
    '''
    Description: calculates value 'a' raised to the power of value 'n' 
    Args: 
        a (int): the base number
        n (int): A non-negative exponent
    Returns: the value of a to the power of n
    '''

    if n > 0:
        return a * powers(a,n-1)
    elif n == 0: 
        return 1
    
def sum_num_digits(n):
    '''
    Description: calculates sum of all digits in a number
    Args: 
        n (int): A positive integer
    Returns: the sum of all digits of n
    ''' 

    if n < 10:
        return n
    else: 
        return sum_num_digits(n // 10) + n % 10 

def fibo(n): 
    '''
    Description: gives you the 'nth' fibonacci number using recursion
    Args: 
        n (int): A non-negative integer representing the position in the Fibonacci Sequence
    Returns: the nth fibonacci number
    '''

    if n == 0:
        return 0 
    elif n == 1:
        return 1
    elif n > 1:
        return fibo(n-1) + fibo(n-2)
    
def GCD(x, y):
    '''
    Description: calculates the greatest common devisor of two numbers using Euclid's Algorithm
    Args: 
        x (int): A positive integer
        y (int): A positive integer
    Returns: the greatest common idivsior between x and y
    ''' 

    if y <= x and x % y == 0:
        return y 
    else: 
        return GCD(y,x % y)
    
def comp_int_bal(p,r,t):
    '''
    Description: calculates balance of value after compound interest is taken into account over time
    Args: 
        p (int): the starting amount 
        r (int): the interest rate
        t (int): number of time periods
    Returns: final balance after compound interest
    '''

    if t == 0: #if time is zero years
        return p #Return original pricipal money
    elif t > 0:
        return (1 + r) * comp_int_bal(p,r,t-1)
    
def product_two_whole_num(a,b):
    '''
    Description: multiplies two whole numbers
    Args: 
        a (int): A whole number
        b (int): A whole number     
    Returns: the product of a and b
    '''
    
    if b > 0:
        return a + product_two_whole_num(a,b-1)
    elif b == 0:
        return 0
    
def SR_Newton(n,p,e):
    '''
    Description: Approximates the square root of a number using Newton's method recursively
    Args: 
        n (float): The number to find the square root of
        p (float): The allowed error tolerance
        e (float): The current estimate
    Returns: The approximation of the square root of n
    '''

    if abs(e^2 - n) < p:
        return e
    else: 
        return SR_Newton((n,p,(e+n)/e)/2)

        
