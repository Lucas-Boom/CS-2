def main(): 
   
    
    player1 = input("Player, what is your name: ") #asks player 1 for name

    board = [['-', '-', '-', '-', '-'],  #board
            ['-', '-', '-', '-', '-'],
            ['-', '-', '-', '-', '-'],
            ['-', '-', '-', '-', '-'], 
            ['-', '-', '-', '-', '-']]
    
    turns = 1
    
    while turns < 12: #if turns are less than 12
            
        if turns == 1:
            place_dots('🛥️', board)
            display_board(board)
            turns += 1

        else:
            if check_winner(board) == False: 
                player_move(player1,'💥', board)
                turns += 1
    else: 
        print("Sorry you are all out of turns")   
        print()
      
